{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test": "vitest run",
    "test:e2e:codegen": "playwright codegen --config=playwright.config.ts http://127.0.0.1:4173/",
    "test:native-smoke": "npm run mobile:sync && cd android && ./gradlew app:assembleDebug",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "prettier --write .",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:assets": "node ./scripts/mobile-assets.mjs",
    "mobile:run:android": "npx cap run android --no-open",
    "mobile:run:ios": "npx cap run ios --no-open",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@playwright/test": "^1.55.1",
    "@sveltejs/vite-plugin-svelte": "^2.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^24.3.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^4.0.0",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.8.3",
    "vite": "^4.0.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/local-notifications": "^6.1.2",
    "@openapitools/openapi-generator-cli": "^2.23.1",
    "date-fns": "^4.1.0",
    "lucide-svelte": "^0.544.0",
    "matrix-js-sdk": "^37.13.0",
    "quick-lru": "^7.1.0"
  }
}
